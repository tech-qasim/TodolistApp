    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saifi.dev04.TodolistApp"
    },
    "android": {
      "adaptiveIcon": {
